RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_DEFAULT_VHOST=/
AMQP_URI = "amqp://guest:guest@localhost:5672/"

#------------Couch Configs---------------#
CB_CONN_STR = 'couchbase://127.0.0.1?dns_srv=false&network=external'
CB_USER = 'Administrator'
CB_PASS = 'secret-password'
CB_SCOPE = '_default'
CB_BUCKET = 'dev-bucker'
CB_EPHEMERAL_BUCKET_NAME = 'pipeline_runs'
LOG_DIR = "/var/log/agentcy"
CB_BUCKET_EPHEMERAL='pipeline_runs'
#-----------Couch Collections------------#

AGENTS_COLLECTION=agents
PIPELINE_COLLECTION=pipelines
PIPELINE_RUNS_COLLECTION=pipeline_runs
PIPELINE_VERSIONING_COLLECTION=pipeline_versioning
PIPELINE_CONFIG_COLLECTION=pipeline_config
PIPELINE_CONFIG_VERSIONING_COLLECTION=pipeline_config_versioning
PIPELINE_RUNS_VERSIONING_COLLECTION=pipeline_runs_versioning
PIPELINE_RUNS_COLLECTION_EPHEMERAL=pipeline_runs_ephemeral
EPHEMERAL_LARGE_OUTPUTS=ephemeral_large_outputs
CB_COLLECTIONS=agents,pipelines,pipeline_runs,pipeline_versioning,pipeline_config,pipeline_config_versioning,catalog,graph_markers,agent_state_registry,agent_state_plan_cache,agent_state_audit_logs,agent_state_pheromones
EPHEMERAL_COLLECTIONS=pipeline_runs_ephemeral,ephemeral_large_outputs
CATALOG_COLLECTION=catalog
GRAPH_MARKERS_COLLECTION=graph_markers

# Foundational agent state collections (persistent)
AGENT_STATE_REGISTRY_COLLECTION=agent_state_registry
AGENT_STATE_PLAN_CACHE_COLLECTION=agent_state_plan_cache
AGENT_STATE_AUDIT_LOGS_COLLECTION=agent_state_audit_logs
AGENT_STATE_PHEROMONES_COLLECTION=agent_state_pheromones

# Pheromone decay configuration (seconds, default: 15 minutes)
PHEROMONE_HALF_LIFE_SECONDS=900


#Communcation kickoff support
PIPELINE_EVENTS_EXCHANGE='pipeline_events_exchange'
PIPELINE_EVENTS_QUEUE='pipeline_events_queue'
PIPELINE_EVENTS_ROUTING_KEY='pipeline.events'


#OCI Settings
NEXUS_PYPI_URL=http://nexus:8081/repository/pypi-internal/
NEXUS_REGISTRY=nexus:5001
NEXUS_USERNAME=svc-agentcy
NEXUS_PASSWORD=Svc-Agentcy-2025!
REGISTRY_USERNAME=svc-agentcy
REGISTRY_PASSWORD=Svc-Agentcy-2025!
TWINE_USERNAME=svc-agentcy
TWINE_PASSWORD=Svc-Agentcy-2025!
TWINE_REPOSITORY_URL=http://nexus:8081/repository/pypi-internal/
PYPI_REPO=pypi-internal
DOCKER_REPO=docker-internal
NEXUS_ADMIN_PASS=Svc-Agentcy-2025!
NEXUS_SVC_RESET=1
NEXUS_SVC_USER=svc-agentcy
NEXUS_SVC_PASS=Svc-Agentcy-2025!


# ---------- Agent launcher (Docker) ----------
AGENT_RUNTIME_IMAGE=agentcy/agent_runtime:base
AGENT_DOCKER_NETWORK=agentcy     # set to your compose network name
AGENT_MEM_LIMIT=512m
AGENT_NANOCPUS=500000000                   # 0.5 CPU
AGENT_FOLLOW_LOGS=1

# ---------- Agent registry (runtime heartbeat) ----------
AGENT_REGISTRY_URL=http://localhost:8002   # required to enable
AGENT_REGISTRY_USERNAME=system
AGENT_ID=                                 # default: service_name-hostname-pid
AGENT_CAPABILITIES=                       # comma-separated
AGENT_TAGS=                               # comma-separated
AGENT_DESCRIPTION=
AGENT_REGISTRY_HEARTBEAT_SECONDS=15
AGENT_REGISTRY_TTL_SECONDS=45             # default: 3x heartbeat, min 30
AGENT_REGISTRY_TIMEOUT_SECONDS=5
AGENT_REGISTRY_FAILURE_THRESHOLD=3

# ---------- Agent registry policy (coverage/freshness/decay) ----------
AGENT_REGISTRY_POLICY_ENABLE=1
AGENT_REGISTRY_POLICY_FILTER_STALE=1
AGENT_REGISTRY_POLICY_INCLUDE_COVERAGE=1
AGENT_REGISTRY_FRESHNESS_WARN_SECONDS=60
AGENT_REGISTRY_FRESHNESS_STALE_SECONDS=300
AGENT_REGISTRY_FRESHNESS_OFFLINE_SECONDS=900
AGENT_REGISTRY_DECAY_HALF_LIFE_SECONDS=900
AGENT_REGISTRY_DECAY_MIN_FACTOR=0.2
AGENT_REGISTRY_COVERAGE_MIN_PER_CAP=1
AGENT_REGISTRY_COVERAGE_TARGET_PER_CAP=3
AGENT_REGISTRY_COVERAGE_MIN_PER_TAG=1
AGENT_REGISTRY_COVERAGE_TARGET_PER_TAG=3
AGENT_REGISTRY_COVERAGE_STATUS_ALLOW=online,idle,busy
AGENT_REGISTRY_POLICY_WEIGHT=0.25

# ---------- LLM Providers ----------
OPEN_AI_KEY=
OPENAI_MODEL=gpt-3.5-turbo
LLM_STRATEGIST_PROVIDER=
LLM_INPUT_VALIDATOR_PROVIDER=
LLM_SUPERVISOR_PROVIDER=
LLM_PLAN_VALIDATOR_PROVIDER=
LLM_ETHICS_PROVIDER=
LLAMA_MODEL=llama3.2:latest

# LLM Fallback Modes:
# LLM_MOCK_MODE=1 - Use mock LLM responses (for testing)
# LLM_STUB_MODE=1 - Use rule-based fallbacks when no provider configured
LLM_MOCK_MODE=0
LLM_STUB_MODE=1

# ---------- Ethics Policy (company rules) ----------
# Enable per-tenant company rules from Couchbase (default: off, uses env-var keyword lists)
ETHICS_ENABLE_COMPANY_RULES=0
# Default keyword lists (used when no per-tenant policy is found)
ETHICS_DESTRUCTIVE_KEYWORDS=delete,remove,drop,truncate,destroy,wipe
ETHICS_PII_KEYWORDS=ssn,social security,credit card,password,secret
ETHICS_BIAS_KEYWORDS=discriminate,exclude,blacklist,whitelist
ETHICS_HALLUCINATION_KEYWORDS=assume,fabricate,invent,guess
# Block plans when no policy found for tenant (0=allow, 1=block)
ETHICS_BLOCK_ON_NO_POLICY=0
# Require human approval when ethics check blocks a high-risk plan
ETHICS_REQUIRE_HUMAN_ON_BLOCK=0
# Max re-evaluations before final veto (0=always veto immediately)
ETHICS_MAX_RE_EVALUATIONS=2
# Queue name for re-evaluation commands
ETHICS_RE_EVALUATION_QUEUE=commands.ethics_re_evaluate

# ---------- Strategist Loop ----------
# Controls the LLM-driven plan revision loop that suggests improvements during execution
LLM_STRATEGIST_LOOP=0
LLM_STRATEGIST_LOOP_PROVIDER=
LLM_STRATEGIST_AUTO_APPLY=0
LLM_STRATEGIST_REQUIRE_HUMAN=1
LLM_STRATEGIST_MIN_INTERVAL_SECONDS=5
LLM_STRATEGIST_MAX_SUGGESTIONS=10
LLM_STRATEGIST_REJECTION_WINDOW=3

# ---------- Observability (Grafana/Loki/Tempo) ----------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_INSECURE=true
GRAFANA_ADMIN_PASSWORD=admin

# ---------- CNP Manager (improved Contract Net Protocol) ----------
# Enable the CNP Manager consumer for full Announce->Bid->Award cycles
CNP_MANAGER_ENABLE=0
# Auto-trigger CNP cycle when a pipeline launches (requires CNP_MANAGER_ENABLE=1)
CNP_AUTO_ON_LAUNCH=0
# Delay between rounds in centralized bidding mode (seconds)
CNP_CENTRALIZED_ROUND_DELAY=0.5
# Prefetch count for the CNP manager consumer
CNP_MANAGER_PREFETCH=5

# ---------- Semantic Layer (Fuseki/SHACL) ----------
# Set FUSEKI_ENABLE=1 to enable Fuseki integration for RDF/SPARQL
FUSEKI_ENABLE=0
FUSEKI_URL=http://fuseki:3030
FUSEKI_DATASET=agentcy
FUSEKI_TIMEOUT=10
FUSEKI_USER=
FUSEKI_PASSWORD=
# SHACL shapes and OWL ontology paths
SHACL_SHAPES_PATH=schemas/plan_draft_shapes.ttl
ONTOLOGY_PATH=schemas/agentcy_ontology.ttl
# Enable/disable RDF export in graph_builder service
SEMANTIC_RDF_EXPORT=1

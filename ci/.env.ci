# .env.ci
# —————————————————————————————————————————————
# Couchbase connection
# —————————————————————————————————————————————
# “CB_CONN_STR” should point to your CB container from the perspective of the CI job—
# if Couchbase is listening on 8091–8094; inside compose, use the service name.
CB_CONN_STR=couchbase://couchbase

# Your Couchbase administrator credentials (create these in your CI startup script)
CB_USER=Administrator
CB_PASS=secret-password

# The bucket and scope you’ve created in Couchbase (make sure your CI script creates them!)
CB_BUCKET=dev-bucker
CB_BUCKET_EPHEMERAL=pipeline_runs
CB_SCOPE=_default


# Persistent collections (must match the keys in your couch/config.py → CB_COLLECTIONS)
# Format: CB_COLLECTIONS__<key>=<collection-name>
# Persistent Couchbase collections
CB_COLLECTIONS_agents=agents
CB_COLLECTIONS_pipelines=pipelines
CB_COLLECTIONS_pipeline_config=pipeline_config
CB_COLLECTIONS_pipeline_versioning=pipeline_versioning
CB_COLLECTIONS_pipeline_config_versioning=pipeline_config_versioning
CB_COLLECTIONS_pipeline_runs_versioning=pipeline_runs_versioning
CB_COLLECTIONS_pipeline_runs=pipeline_runs
CB_COLLECTIONS_catalog=catalog
CB_COLLECTIONS_graph_markers=graph_markers

# Ephemeral collections
EPHEMERAL_COLLECTIONS_pipeline_runs_ephemeral=pipeline_runs_ephemeral
EPHEMERAL_COLLECTIONS_ephemeral_outputs=ephemeral_large_outputs


# —————————————————————————————————————————————
# RabbitMQ connection
# —————————————————————————————————————————————
# Point this at your Rabbit container—if you’re mapping 5672→5672 on localhost:
AMQP_URI=amqp://guest:guest@localhost:5672/

# Optional: if you use a non-default vhost in your tests
RABBITMQ_VHOST=/

{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Endpoint",
    "type": "object",
    "required": ["name", "path", "methods"],
    "properties": {
      "name": {
        "type": "string",
        "description": "Logical name of the endpoint (e.g., 'create_order')."
      },
      "path": {
        "type": "string",
        "description": "Relative path of the endpoint (e.g., '/api/v1/orders/create')."
      },
      "methods": {
        "type": "array",
        "description": "Supported HTTP methods for the endpoint.",
        "items": {
          "$ref": "../enums/Enums.json#/properties/httpMethodsEnum"
        },
        "minItems": 1
      },
      "description": {
        "type": "string",
        "description": "Detailed description of the endpoint's functionality."
      },
      "parameters": {
        "type": "array",
        "description": "List of parameters accepted by the endpoint.",
        "items": {
          "$ref": "Parameter.json"
        }
      }
    },
    "additionalProperties": false
  }
  